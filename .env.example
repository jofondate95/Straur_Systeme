# === DATABASE ===
DATABASE_URL=postgresql://straur_user:straur_password@localhost:5432/straur_db
REDIS_URL=redis://localhost:6379

# === JWT ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRATION=7d

# === OTP SMS ===
OTP_EXPIRATION=300
OTP_LENGTH=6
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# === MOBILE MONEY ===
MTN_MOMO_API_KEY=your-mtn-momo-api-key
MTN_MOMO_PRIMARY_KEY=your-mtn-momo-primary-key
ORANGE_MONEY_API_KEY=your-orange-money-api-key
ORANGE_MONEY_SECRET=your-orange-money-secret

# === FIREBASE ===
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# === GOOGLE MAPS ===
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# === QR CODE ===
QR_CODE_ENCRYPTION_KEY=your-aes-256-encryption-key-32-bytes
QR_CODE_VALIDITY_MINUTES=30
QR_CODE_HMAC_SECRET=your-hmac-secret-key

# === APPLICATION ===
NODE_ENV=development
PORT=3000
APP_NAME=STraur
APP_URL=http://localhost:3000

# === SOCKET.IO ===
SOCKET_PORT=3001
SOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8081

# === LOGGING ===
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# === RATE LIMITING ===
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100
