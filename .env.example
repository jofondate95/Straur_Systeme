# ============================================
# CONFIGURATION ENVIRONMENT - STraur
# ============================================

# GENERAL
NODE_ENV=development
PORT=3000
APP_NAME=STraur
APP_VERSION=1.0.0

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://straur_user:straur_password@localhost:5432/straur_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=straur_user
DATABASE_PASSWORD=straur_password
DATABASE_NAME=straur_db

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# ============================================
# OTP & SMS
# ============================================
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your-twilio-account-sid
SMS_AUTH_TOKEN=your-twilio-auth-token
SMS_FROM_NUMBER=+1234567890
OTP_EXPIRATION=300
OTP_RESEND_COOLDOWN=60

# ============================================
# MOBILE MONEY - MTN MoMo
# ============================================
MTN_MOMO_API_KEY=your-mtn-api-key
MTN_MOMO_API_SECRET=your-mtn-api-secret
MTN_MOMO_SUBSCRIBER_KEY=your-mtn-subscriber-key
MTN_MOMO_PRIMARY_KEY=your-mtn-primary-key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=EUR

# ============================================
# MOBILE MONEY - Orange Money
# ============================================
ORANGE_MONEY_API_KEY=your-orange-api-key
ORANGE_MONEY_API_SECRET=your-orange-api-secret
ORANGE_MONEY_MERCHANT_ID=your-merchant-id
ORANGE_MONEY_ENVIRONMENT=sandbox

# ============================================
# QR CODE ENCRYPTION
# ============================================
QR_CODE_SECRET_KEY=your-aes-256-secret-key-32-chars-min
QR_CODE_VALIDITY_MINUTES=30
QR_CODE_ALGORITHM=aes-256-cbc

# ============================================
# FIREBASE - Cloud Messaging
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ============================================
# GOOGLE MAPS
# ============================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_BROWSER_KEY=your-google-maps-browser-key
GOOGLE_MAPS_PLACES_API_KEY=your-places-api-key

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENABLED=false

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:8081
CORS_CREDENTIALS=true
RATIONAL_LIMIT_WINDOW=15
RATIONAL_LIMIT_MAX_REQUESTS=100

# ============================================
# MAIL SERVICE
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@straur.dev
MAIL_FROM_NAME=STraur Support

# ============================================
# AWS S3 (pour upload documents, photos)
# ============================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=straur-uploads
AWS_S3_ACL=public-read

# ============================================
# SOCKET.IO - Real-time
# ============================================
SOCKET_IO_CORS_ORIGIN=http://localhost:3001,http://localhost:3002
SOCKET_IO_PING_INTERVAL=25000
SOCKET_IO_PING_TIMEOUT=60000

# ============================================
# PAYMENT - Commission & Tarification
# ============================================
COMMISSION_PERCENTAGE=5
MIN_WALLET_RECHARGE=1000
MAX_WALLET_RECHARGE=1000000
FIDELITY_POINTS_PER_TRIP=10
FREE_TRIP_AT_POINTS=100

# ============================================
# FRONTEND MOBILE CONFIG
# ============================================
REACT_NATIVE_API_URL=http://localhost:3000/api
REACT_NATIVE_SOCKET_IO_URL=http://localhost:3000

# ============================================
# FRONTEND ADMIN CONFIG
# ============================================
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_SOCKET_IO_URL=http://localhost:3000

# ============================================
# TERMINAL PWA CONFIG
# ============================================
REACT_APP_TERMINAL_API_URL=http://localhost:3000/api
REACT_APP_TERMINAL_SOCKET_IO_URL=http://localhost:3000

# ============================================
# EXPIRATION & TIMEOUTS
# ============================================
REFRESH_TOKEN_EXPIRY=604800
ACCESS_TOKEN_EXPIRY=86400
SESSION_TIMEOUT=3600
